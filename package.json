{
  "name": "@alex_moroz/claude-codex-router",
  "version": "0.1.1",
  "description": "Local macOS control panel for Claude Code to Codex delegation through the official Codex Claude plugin.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/alex-moroz-plt/claude-codex-router-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-moroz-plt/claude-codex-router-ui.git"
  },
  "bugs": {
    "url": "https://github.com/alex-moroz-plt/claude-codex-router-ui/issues"
  },
  "bin": {
    "claude-codex-router": "bin/claude-codex-router.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "router",
    "pwa",
    "macos",
    "ai-coding",
    "developer-tools"
  ],
  "files": [
