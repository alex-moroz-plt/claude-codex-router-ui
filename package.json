    "public/app.js",
    "public/index.html",
    "public/manifest.webmanifest",
    "public/styles.css",
    "public/sw.js",
    "public/icons/",
    "scripts/build-portable-package.mjs",
    "scripts/generate-icons.mjs",
    "telemetry/",
    "Build Portable Installer.command",
    "Install Desktop PWA.command",
    "Uninstall Background Service.command",
    "start.command",
    "server.mjs",
    "setup-manager.mjs",
    "telemetry-manager.mjs",
    "usage-history.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test test/*.test.mjs",
    "pack:check": "npm pack --dry-run"
  }
